# Copy this file to .env.local and fill in your values
# Never commit .env.local to git

# Supabase — from your project settings → Settings → API
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# The following are for Netlify Functions only (add in Netlify dashboard → Site settings → Env vars)
# SUPABASE_URL=https://xxxx.supabase.co            (same as above, without VITE_ prefix)
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key  (from Supabase → Settings → API → service_role)
# PAYFAST_MERCHANT_ID=10000100                     (sandbox default, swap for live later)
# PAYFAST_MERCHANT_KEY=46f0cd694581a               (sandbox default)
# PAYFAST_PASSPHRASE=your_passphrase               (set in PayFast dashboard)
# PAYFAST_SANDBOX=true                             (set to "false" when going live)
# SITE_URL=https://your-site.netlify.app           (your deployed URL)
